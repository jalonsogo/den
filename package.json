{
  "name": "den",
  "version": "0.7.1",
  "description": "A beautiful GUI for Docker Sandboxes",
  "main": "./out/main/index.js",
  "desktopName": "den",
  "homepage": "https://den.studio",
  "repository": {
    "type": "git",
    "url": "https://github.com/krissetto/den.git"
  },
  "author": {
    "name": "den",
    "email": "javier.alonso@docker.com",
    "url": "https://den.studio"
  },
  "license": "MIT",
  "build": {
    "appId": "studio.den.app",
    "productName": "den",
    "publish": [
      {
        "provider": "github"
      }
    ],
    "mac": {
      "icon": "resources/icon/dock.png",
      "notarize": true,
      "identity": "Javier Alonso Gómez (2KVDGP5463)"
    },
    "win": {
      "icon": "resources/icon/dock.png"
    },
    "linux": {
      "target": "deb",
      "icon": "resources/icon/linux",
      "category": "Development",
      "packageCategory": "devel",
      "synopsis": "Desktop GUI for Docker Sandboxes",
      "syncDesktopName": true
    }
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "sync:icons": "node scripts/sync-icons.mjs",
    "build:mac": "npm run build && electron-builder --mac",
    "build:win": "npm run build && electron-builder --win",
    "build:linux:x64": "npm run build && electron-builder --linux deb --x64",
    "build:linux:arm64": "npm run build && electron-builder --linux deb --arm64",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@basiclines/rampa-sdk": "6.0.0",
    "@electron-toolkit/preload": "3.0.2",
    "@electron-toolkit/utils": "4.0.0",
    "@fontsource/figtree": "5.2.10",
    "@fontsource/fraunces": "5.2.9",
    "@lobehub/icons": "5.13.0",
    "@radix-ui/react-dialog": "1.1.19",
    "@radix-ui/react-dropdown-menu": "2.1.20",
    "@radix-ui/react-scroll-area": "1.2.14",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-switch": "1.3.3",
    "@radix-ui/react-tabs": "1.1.17",
    "@radix-ui/react-tooltip": "1.2.12",
    "@wterm/dom": "0.3.0",
    "@wterm/react": "0.3.0",
    "@xterm/addon-fit": "0.11.0",
    "@xterm/addon-web-links": "0.12.0",
    "@xterm/xterm": "6.0.0",
    "electron-store": "11.0.2",
    "highlight.js": "11.11.1",
    "lucide-react": "1.24.0",
    "node-pty": "1.1.0",
    "react-markdown": "10.1.0",
    "rehype-highlight": "7.0.2",
    "rehype-raw": "7.0.0",
    "remark-gfm": "4.0.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "2.0.0",
    "@electron/rebuild": "4.2.0",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "typescript": "7.0.2",
    "vite": "7.3.6"
  },
  "engines": {
    "node": "26.5.0",
    "npm": "12.0.1"
  },
  "packageManager": "npm@12.0.1",
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "node-pty@1.1.0": true,
    "electron-winstaller@5.4.0": true
  }
}
